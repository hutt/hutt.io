<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} – {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ beschreibung if beschreibung else site.beschreibung }}">
  <meta name="author" content="{{ site.autor }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} – {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ beschreibung if beschreibung else site.beschreibung }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Favicons -->
  <link rel="icon" href="/assets/img/favicon.ico" sizes="any">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png">

  <!-- Fonts (self-hosted – kein Third-Party-Request) -->
  <link rel="preload" href="/assets/fonts/CabinetGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/GeneralSans-Variable.woff2" as="font" type="font/woff2" crossorigin>

  <!-- CSS -->
  <link rel="stylesheet" href="/assets/css/style.css">

  <!-- Plausible Analytics (self-hosted, DSGVO-konform, kein Cookie) -->
  <script defer data-domain="{{ site.plausible_domain }}" data-api="/pa/event" src="/pa/script.file-downloads.outbound-links.pageview-props.js"></script>
</head>
<body>

<!-- Skip Link -->
<a class="skip-link" href="#main">Zum Inhalt springen</a>

<!-- Header -->
<header class="header" role="banner">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="{{ site.title }} – Startseite">hutt<span>.</span></a>
    <nav aria-label="Hauptnavigation">
      <a href="/#ueber-mich" class="nav-link">Über mich</a>
      <a href="/#projekte" class="nav-link">Projekte</a>
      <a href="/#jobs" class="nav-link">Jobs</a>
      <a href="/#kontakt" class="nav-link">Kontakt</a>
      <button class="theme-toggle" data-theme-toggle aria-label="Zum hellen Modus wechseln">
        <!-- Icon wird per JS gesetzt -->
      </button>
    </nav>
  </div>
</header>

<!-- Main -->
<main id="main">
  {{ content | safe }}
</main>

<!-- Footer -->
<footer class="footer">
  <div class="footer-inner">
    <p class="footer-copy">
      © 2010 – {% jahr %} {{ site.autor }} &nbsp;·&nbsp;
      <a href="/datenschutz/">Datenschutz</a> &nbsp;·&nbsp;
      <a href="/impressum/">Impressum</a>
    </p>
    <p class="footer-meta">
      Gebaut mit <a href="https://www.11ty.dev" target="_blank" rel="noopener">Eleventy</a>.
      Kein Tracking außer <a href="https://plausible.io" target="_blank" rel="noopener">Plausible</a>.
    </p>
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
